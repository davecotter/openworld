        "CMAKE_OSX_SYSROOT": "xrsimulator",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "2.0",
        "SOS_BUILD_TESTS": "OFF"
      },
      "environment": {
        "PATH": "/Users/davec/Developer/Qt/Tools/CMake/CMake.app/Contents/bin:/Users/davec/Developer/Qt/Tools/Ninja:$penv{PATH}",
        "DEVELOPER_DIR": "/Applications/Xcode-27.0.0-Beta.2.app/Contents/Developer"
      }
    },
    {
      "name": "ios-debug",
      "displayName": "iOS Device Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/ios",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_OSX_SYSROOT": "iphoneos",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "17.0",
        "SOS_BUILD_TESTS": "OFF"
      },
      "environment": {
        "PATH": "/Users/davec/Developer/Qt/Tools/CMake/CMake.app/Contents/bin:/Users/davec/Developer/Qt/Tools/Ninja:$penv{PATH}",
        "DEVELOPER_DIR": "/Applications/Xcode-27.0.0-Beta.2.app/Contents/Developer"

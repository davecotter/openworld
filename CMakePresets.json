    { "name": "qt-host-release", "configurePreset": "qt-host-release" },
    { "name": "xros-debug", "configurePreset": "xros-debug" },
    { "name": "xros-simulator-debug", "configurePreset": "xros-simulator-debug" },
    { "name": "ios-debug", "configurePreset": "ios-debug" },

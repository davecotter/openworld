{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "qt-host-debug",
      "displayName": "Host Debug (Qt Creator / macOS)",
      "description": "Build sos-core on macOS using bundled Qt CMake + Ninja",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/host",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_PREFIX_PATH": "/Users/davec/Developer/Qt/6.11.1/macos",
        "SOS_BUILD_TESTS": "ON"
      },
      "environment": {
        "PATH": "/Users/davec/Developer/Qt/Tools/CMake/CMake.app/Contents/bin:/Users/davec/Developer/Qt/Tools/Ninja:$penv{PATH}"
      }
    },
    {
      "name": "qt-host-release",
      "inherits": "qt-host-debug",
      "displayName": "Host Release (Qt Creator / macOS)",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "xros-debug",
      "displayName": "visionOS Device Debug",
      "generator": "Ninja",
